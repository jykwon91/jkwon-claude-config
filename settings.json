{
  "model": "opus",
  "effortLevel": "high",
  "autoCompactWindow": 300000,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(*)",
            "command": "node $HOME/.claude/hooks/block-drop-database.js",
            "timeout": 5000,
            "statusMessage": "Guarding against irreversible DROP DATABASE / dropdb..."
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node $HOME/.claude/hooks/block-commit-to-main.js",
            "timeout": 5000,
            "statusMessage": "Checking branch before commit..."
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node $HOME/.claude/hooks/validate-commit.js",
            "timeout": 5000,
            "statusMessage": "Validating commit message format..."
          },
          {
            "type": "command",
            "if": "Bash(git push:*)",
            "command": "node $HOME/.claude/hooks/check-pr-not-merged.js",
            "timeout": 10,
            "statusMessage": "Checking if PR is already merged..."
          },
          {
            "type": "command",
            "if": "Bash(gh pr create*)",
            "command": "node $HOME/.claude/hooks/pr-quality-gate.js",
            "timeout": 120,
            "statusMessage": "Pipeline quality gate — checking E2E tests, architecture, and standards..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/cleanup-after-merge.js",
            "timeout": 15,
            "statusMessage": "Checking if branch can be cleaned up..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/read-injection-scanner.js",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/state-update-reminder.js",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
